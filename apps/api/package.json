{
  "name": "@open-escrow/api",
  "version": "0.1.0",
  "private": true,
  "description": "OpenEscrow backend API — Fastify + TypeScript + Drizzle ORM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify-type-provider-zod": "^2.1.0",
    "@open-escrow/shared": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "ethers": "^6.13.0",
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "siwe": "^2.3.2",
    "uuid": "^10.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
