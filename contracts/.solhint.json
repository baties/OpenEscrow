{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", "^0.8.0"],
    "avoid-suicide": "error",
    "avoid-sha3": "warn",
    "no-empty-blocks": "warn",
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "no-unused-vars": "warn",
    "reason-string": "warn",
    "quotes": "off",
    "use-natspec": "warn",
    "gas-indexed-events": "warn",
    "gas-strict-inequalities": "warn"
  }
}
