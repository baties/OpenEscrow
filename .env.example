###############################################################################
# .env.example — OpenEscrow MVP
#
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# All variables without defaults marked :?VAR are REQUIRED.
###############################################################################

# ─── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Database credentials for PostgreSQL.
POSTGRES_USER=escrow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=open_escrow
POSTGRES_PORT=5432

# Full connection URL used by Drizzle ORM (api service).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://escrow:change_me_strong_password@localhost:5432/open_escrow

# ─── API (Fastify backend) ────────────────────────────────────────────────────
API_PORT=3001
LOG_LEVEL=info

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRY=24h

# CORS — web dashboard origin only, no wildcard in production
ALLOWED_ORIGIN=http://localhost:3000

# Internal secret for bot → API authentication (generate: openssl rand -hex 32)
BOT_API_SECRET=replace_with_32_char_hex_secret

# ─── Smart Contract (Chain indexer + Web) ─────────────────────────────────────
# Chain ID: 11155111 = Ethereum Sepolia testnet (mainnet only after audit)
CHAIN_ID=11155111

# Deployed OpenEscrow contract address (populated after contracts-agent runs)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Sepolia RPC endpoint (get from Alchemy / Infura / QuickNode)
# IMPORTANT: Do NOT hardcode — use a project-specific RPC endpoint
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Sepolia stablecoin addresses (USDC and USDT test tokens)
USDC_ADDRESS=0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8
USDT_ADDRESS=0xaA8E23Fb1079EA71e0a56F48a2aA51851D8433D0

# Chain indexer poll interval in milliseconds (12000 = 12 seconds per MVP spec)
INDEXER_POLL_INTERVAL_MS=12000

# ─── Web Dashboard (Next.js) ──────────────────────────────────────────────────
WEB_PORT=3000

# Public API URL accessible from the browser (not internal Docker hostname)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WalletConnect project ID (get from https://cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=000000000:AABBCCDDEEFFaabbccddeeff-your_token

# API base URL as seen by the bot container (internal Docker network)
BOT_API_BASE_URL=http://api:3001

# Notification polling interval in milliseconds (30000 = 30 seconds per MVP spec)
BOT_POLL_INTERVAL_MS=30000

# ─── Deployer (contracts only — never used at runtime) ────────────────────────
# Private key for Hardhat deploy scripts — Sepolia only, never mainnet
# WARNING: Only use a dedicated deploy wallet. Never use a wallet holding real funds.
# DEPLOYER_PRIVATE_KEY=0x_your_deploy_wallet_private_key
